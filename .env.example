# ReClaw agent configuration
AGENT_NAME=ReClaw
RECLAW_PROVIDER=demo
USER_NAME=
USER_WORK=

# pro | max5x | max20x
CLAUDE_TIER=pro
HEARTBEAT_INTERVAL=60
HEARTBEAT_ON_START=false

# Auth: use either Anthropic API key or Claude Code OAuth (`claude auth`)
ANTHROPIC_API_KEY=

# Discord is optional. If empty, the agent runs in console mode.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Workspace paths
RECLAW_HOME=.
MEMORY_DIR=memory
LOG_LEVEL=info
